# ─────────────────────────────────────────────────────────────
# Find-It 환경 변수 템플릿
# 실제 값은 .env.local 에 채워 넣으세요 (.env.local 은 git 에 커밋되지 않습니다).
#
# ⚠️ VITE_ 접두사 변수는 모두 클라이언트 번들에 인라인됩니다.
#    즉 브라우저에서 그대로 노출되므로 "비밀값"으로 취급할 수 없습니다.
# ─────────────────────────────────────────────────────────────

# 백엔드 API (findit-server)
# 미설정 시 동일 출처 /api 로 폴백합니다 (Vercel rewrite가 백엔드로 프록시).
VITE_API_BASE_URL="https://your-backend-host/api"
VITE_API_SECURITY_KEY="your-backend-api-key"

# 앱 배포 URL (OG/Helmet 용)
VITE_APP_BASE_URL="https://your-app.vercel.app/"

# 행정표준코드(SGIS) API — 회원가입/프로필의 시도·군구 선택에 사용
VITE_AUTH_API_URL="https://sgisapi.kostat.go.kr/OpenAPI3/auth/authentication.json"
VITE_LOCAL_API_URL="https://sgisapi.kostat.go.kr/OpenAPI3/addr/stage.json"
VITE_CONSUMERKEY="your-sgis-consumer-key"
VITE_CONSUMERSECRET="your-sgis-consumer-secret"

# Kakao Maps JavaScript 키는 index.html 의 SDK script 태그에 들어갑니다.
# (도메인 허용 목록으로 보호 — Kakao 개발자 콘솔에서 설정)
