{
  "buildCommand": "pnpm run build",
  "outputDirectory": "dist",
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "https://findit-api.devyoung.dev/api/$1"
    },
    {
      "source": "/uploads/(.*)",
      "destination": "https://findit-api.devyoung.dev/uploads/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
